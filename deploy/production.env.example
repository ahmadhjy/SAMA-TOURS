# One-time setup on PythonAnywhere:
#   cp deploy/production.env.example deploy/production.env
#   nano deploy/production.env
#
# Copy values from your WSGI file. Do not commit production.env to git.

DJANGO_SECRET_KEY='replace-with-your-secret-key'
DJANGO_ALLOWED_HOSTS=main-samatours2026.pythonanywhere.com,www.samatourslb.com,samatourslb.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://main-samatours2026.pythonanywhere.com,https://www.samatourslb.com,https://samatourslb.com
DJANGO_DEBUG=False

DJANGO_DB_ENGINE=postgresql
DJANGO_DB_NAME=sama_website
DJANGO_DB_USER=sama_web
DJANGO_DB_PASSWORD='replace-with-db-password'
DJANGO_DB_HOST=Samatours2026-5298.postgres.pythonanywhere-services.com
DJANGO_DB_PORT=15298

# Optional — auto-reload after deploy. Path from Web tab → WSGI file link.
# PA_WSGI_FILE=/var/www/main_samatours2026_pythonanywhere_com_wsgi.py
