# Environment variables — copy to .env for local use (do not commit .env)

# Required in production
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=yourusername.pythonanywhere.com,www.samatourslb.com
CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com,https://www.samatourslb.com

# Static files (PythonAnywhere)
USE_WHITENOISE=True

# PostgreSQL (PythonAnywhere — from your Databases tab)
DB_NAME=yourusername$samatours
DB_USER=yourusername
DB_PASSWORD=your-db-password
DB_HOST=yourusername.postgres.pythonanywhere-services.com
DB_PORT=5432

# Media uploads path on PythonAnywhere (optional — defaults to project/media)
# MEDIA_ROOT=/home/yourusername/samatours/media
